---
import Header from '../components/itechie/Header.astro';
import Footer from '../components/itechie/Footer.astro';
import { readData } from '../lib/readData';

interface Props {
  title?: string;
  description?: string;
}

const siteConfig = readData('siteConfig.json');
const { title = siteConfig.name, description = siteConfig.description } = Astro.props;
const formattedTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;

function hexToRgb(hex: string) {
  const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
  return result ? `${parseInt(result[1], 16)}, ${parseInt(result[2], 16)}, ${parseInt(result[3], 16)}` : '46, 56, 220';
}

function hexToHue(hex: string) {
  let r = 0, g = 0, b = 0;
  if (hex.length === 4) {
    r = parseInt(hex[1] + hex[1], 16); g = parseInt(hex[2] + hex[2], 16); b = parseInt(hex[3] + hex[3], 16);
  } else {
    r = parseInt(hex[1] + hex[2], 16); g = parseInt(hex[3] + hex[4], 16); b = parseInt(hex[5] + hex[6], 16);
  }
  r /= 255; g /= 255; b /= 255;
  let max = Math.max(r, g, b), min = Math.min(r, g, b);
  let h = 0, s, l = (max + min) / 2;
  if (max === min) { h = s = 0; } else {
    let d = max - min;
    s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
    switch (max) {
      case r: h = (g - b) / d + (g < b ? 6 : 0); break;
      case g: h = (b - r) / d + 2; break;
      case b: h = (r - g) / d + 4; break;
    }
    h /= 6;
  }
  return Math.round(h * 360);
}

const theme = siteConfig.theme;
const primaryRgb = hexToRgb(theme?.primary || '#2e38dc');
const secondaryRgb = hexToRgb(theme?.secondary || '#111111');
const bgDarkRgb = hexToRgb(theme?.bgDark || '#0b0d26');
const mainHue = hexToHue(theme?.primary || '#2e38dc');

// Filtro de Precisão: Transforma Azul #2e38dc em CMS Primary
// 1. brightness(0) -> Preto
// 2. invert(1) -> Branco (ou inverter para matiz alvo)
// 3. sepia(1) saturate(5) hue-rotate(...) -> Cor Alvo
const shapeFilter = `brightness(0) saturate(100%) invert(1) sepia(1) saturate(5) hue-rotate(${mainHue - 50}deg)`;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{formattedTitle}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/webp" href="/favicon.webp" />
  
  <!-- Preload LCP (Banner Image) - Usando o caminho fixo que o Astro otimiza -->
  <link rel="preload" as="image" href="/itechie-assets/img/banner/bg-real.webp" fetchpriority="high" />

  <!-- Google Fonts otimizadas -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  
  <!-- CSS Crítico Inline (Para acelerar FCP/LCP no Mobile) -->
  <style is:inline define:vars={{ primaryRgb, bgDarkRgb, mainHue, shapeFilter }}>
    :root {
      --main-color: rgb(var(--primaryRgb));
      --heading-color: #151423;
      --body-font: "Rubik", sans-serif;
      --heading-font: "Rajdhani", sans-serif;
    }
    body { margin: 0; font-family: var(--body-font); background: #0b0d26; color: #fff; }
    .banner-area-2 { min-height: 800px; display: flex; align-items: center; position: relative; overflow: hidden; background: #0b0d26; }
    .hero-bg-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
    .bg-overlay-gradient { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; background: linear-gradient(to right, #000 0%, rgba(var(--bg-dark-rgb), 1) 30%, rgba(var(--bg-dark-rgb), 0.4) 100%); }
    .banner-inner { position: relative; z-index: 2; padding-top: 100px; }
    .banner-inner .title { font-size: 42px; color: #fff; font-family: var(--heading-font); font-weight: 700; line-height: 1.2; }
    @media (min-width: 992px) { .banner-inner .title { font-size: 60px; } }
  </style>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" />
  
  <!-- CSS Essencial (Preload para carregar junto com o Inline) -->
  <link rel="preload" href="/itechie-assets/css/bootstrap.min.css" as="style" />
  <link rel="preload" href="/itechie-assets/css/style.css" as="style" />
  <link rel="stylesheet" href="/itechie-assets/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/itechie-assets/css/style.css" />
  <link rel="stylesheet" href="/itechie-assets/css/responsive.css" />
  
  <!-- CSS Plugins (Deferred for PageSpeed) -->
  <link rel="preload" href="/itechie-assets/css/animate.min.css" as="style" />
  <link rel="stylesheet" href="/itechie-assets/css/animate.min.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/itechie-assets/css/fontawesome.min.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/itechie-assets/css/custom-icon.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/itechie-assets/css/nice-select.min.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/itechie-assets/css/magnific.min.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/itechie-assets/css/slick.min.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/itechie-assets/css/owl.min.css" media="print" onload="this.media='all'" />
  
  <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" />
      <link rel="stylesheet" href="/itechie-assets/css/animate.min.css" />
      <link rel="stylesheet" href="/itechie-assets/css/fontawesome.min.css" />
      <link rel="stylesheet" href="/itechie-assets/css/custom-icon.css" />
      <link rel="stylesheet" href="/itechie-assets/css/nice-select.min.css" />
      <link rel="stylesheet" href="/itechie-assets/css/magnific.min.css" />
      <link rel="stylesheet" href="/itechie-assets/css/slick.min.css" />
      <link rel="stylesheet" href="/itechie-assets/css/owl.min.css" />
  </noscript>

  <style is:global define:vars={{ 
    primaryColor: theme?.primary || '#2e38dc',
    secondaryColor: theme?.secondary || '#0b0d26',
    accentColor: theme?.accent || '#007bff',
    bgDark: theme?.bgDark || '#0b0d26',
    bgLight: theme?.bgLight || '#f4f4ff',
    textOnPrimary: theme?.textOnPrimary || '#ffffff',
    primaryRgb: primaryRgb || '46, 56, 220',
    secondaryRgb: secondaryRgb || '17, 17, 17',
    bgDarkRgb: bgDarkRgb || '11, 13, 38',
    mainHue: mainHue,
    shapeFilter: shapeFilter
  }}>
    /* Critical CSS for LCP */
    .banner-area { position: relative; background-size: cover; background-position: center; }
    .banner-inner { position: relative; z-index: 5; }
    .banner-inner .title { font-size: 78px; line-height: 1.05; font-weight: 700; color: #fff; font-family: 'Rajdhani', sans-serif; }
    .banner-area-2 { padding: 250px 0 250px 0; }
    .navbar-area { position: absolute; width: 100%; z-index: 99; padding: 0; }
    @media only screen and (max-width: 991px) {
      .banner-inner .title { font-size: 42px; line-height: 1.2; }
      .banner-area-2 { padding: 160px 0 100px 0; }
      .navbar-area { background: #fff; }
    }

    :root {
      --main-color: var(--primaryColor);
      --main-color-rgb: var(--primaryRgb);
      --main-color-hue: var(--mainHue);
      --main-color-filter: var(--shapeFilter);
      --secondary-color: var(--secondaryColor);
      --secondary-color-rgb: var(--secondaryRgb);
      --accent-color: var(--accentColor);
      --bg-dark: var(--bgDark);
      --bg-dark-rgb: var(--bgDarkRgb);
      --bg-light: var(--bgLight);
      --text-on-primary: var(--textOnPrimary);
      --color-primary: var(--primaryColor);
    }

    /* Utilitários de Cor de Fundo */
    .bg-main-base { background-color: var(--main-color) !important; }
    .bg-dark-base { background-color: var(--bg-dark) !important; }
    .bg-light-base { background-color: var(--bg-light) !important; }
    .bg-sky-blue { background-color: var(--bg-light); }
    
    /* Máscara Dinâmica para Shapes (SUBSTITUI FILTROS BUGADOS) */
    .mask-primary {
      background-color: var(--main-color) !important;
      -webkit-mask-repeat: no-repeat;
      mask-repeat: no-repeat;
      -webkit-mask-size: contain;
      mask-size: contain;
      -webkit-mask-position: center;
      mask-position: center;
    }
    .mask-secondary {
       background-color: var(--secondary-color) !important;
    }
    .mask-opacity {
       opacity: 0.15 !important;
    }
    .pd-top-120 { padding-top: 120px; }
    .pd-bottom-90 { padding-bottom: 90px; }
    .pd-top-115 { padding-top: 115px; }
    .pd-top-90 { padding-top: 90px; }
    .pd-bottom-120 { padding-bottom: 120px; }
    .mg-top--100 { margin-top: -100px; z-index: 2; position: relative; }

    /* Button Padding & Style Fix */
    .it-btn, .btn-base, .btn-black {
      padding: 12px 30px !important;
      display: inline-block;
      text-align: center;
      font-weight: 500;
      transition: all 0.4s ease;
      border-radius: 4px;
      line-height: 1;
    }
    .btn-black {
      background: #000 !important;
      color: #fff !important;
    }
    .btn-black:hover {
      background: var(--color-primary) !important;
    }

    /* Progress Bar Styles */
    .single-progressbar {
      margin-bottom: 25px;
    }
    .single-progressbar h6 {
      margin-bottom: 10px;
      font-size: 16px;
      font-weight: 600;
    }
    .progress-item {
      height: 8px;
      background: #e9ecef;
      border-radius: 10px;
      position: relative;
    }
    .progress-rate {
      height: 100%;
      background: var(--color-primary);
      border-radius: 10px;
      position: relative;
      transition: width 2s ease-in-out;
    }
    .progress-count-wrap {
      position: absolute;
      right: 0;
      top: -30px;
      font-weight: 600;
      color: #333;
    }

    /* Header Nav Fix - Moved to Header.astro */
  </style>
  <style is:global>
    /* REMOVER O "T" FANTASMA QUE APARECE NO MENU */
    .navbar-nav li:before,
    .navbar-nav li:after,
    .navbar-nav li a:before,
    .navbar-nav li a:after,
    .navbar-area .nav-container .navbar-collapse .navbar-nav li:after,
    .navbar-area-2 .navbar-nav li:after {
      content: none !important;
      display: none !important;
      visibility: hidden !important;
      width: 0 !important;
      height: 0 !important;
    }

    /* AJUSTES DE RESPONSIVIDADE GLOBAL */
    @media (max-width: 768px) {
      .pd-top-120 { padding-top: 60px !important; }
      .pd-bottom-90 { padding-bottom: 45px !important; }
      .pd-top-115 { padding-top: 60px !important; }
      .pd-top-90 { padding-top: 45px !important; }
      .pd-bottom-120 { padding-bottom: 60px !important; }
      
      h1, .h1 { font-size: 32px !important; line-height: 1.2 !important; }
      h2, .h2 { font-size: 28px !important; line-height: 1.3 !important; }
      h3, .h3 { font-size: 24px !important; line-height: 1.3 !important; }
      
      .banner-inner .title {
        font-size: 36px !important;
        margin-bottom: 20px !important;
      }
      
      .section-title .title {
        font-size: 30px !important;
      }

      .it-btn {
        width: 100%;
        margin-bottom: 10px;
      }
      
      .mg-top--100 {
        margin-top: -50px !important;
      }

      /* Fix overflowing text */
      p, span, a, h1, h2, h3, h4, h5, h6 {
        overflow-wrap: break-word;
        word-wrap: break-word;
      }
      
      /* Footer adjustments */
      .footer-area .widget {
          margin-bottom: 40px;
      }

      /* About Section Fixes */
      .experience-badge {
          left: 10px !important;
          top: 10px !important;
          padding: 15px 10px !important;
      }
      .experience-badge h2 {
          font-size: 24px !important;
      }
      .experience-badge p {
          font-size: 10px !important;
      }
      .main-img-2 {
          display: none !important;
      }

      /* Service Card Fixes */
      .single-service-inner {
          margin-bottom: 30px;
          padding: 40px 20px !important;
      }
      .single-service-inner .details h3 {
          font-size: 20px !important;
      }
      
      /* Testimonial Fixes */
      .testimonial-slider .item {
          padding: 0 15px;
      }
    }
  </style>
</head>
<body class="sc5">
  
  <Header />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- ALL JavaScript files (Lazy Loaded for Max PageSpeed) -->
  <script is:inline>
    (function() {
      let scriptsLoaded = false;
      const loadScripts = () => {
        if(scriptsLoaded) return;
        scriptsLoaded = true;
        const scripts = [
          "https://code.jquery.com/jquery-3.7.1.min.js",
          "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js",
          "https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js",
          "https://cdn.jsdelivr.net/npm/magnific-popup@1.1.0/dist/jquery.magnific-popup.min.js",
          "https://cdn.jsdelivr.net/npm/jquery-nice-select@1.1.0/js/jquery.nice-select.min.js",
          "/js/jquery.sticky-sidebar.min.js",
          "/js/custom.js"
        ];
        
        const loadScript = (src) => {
          return new Promise(resolve => {
            const s = document.createElement('script');
            s.src = src;
            s.onload = resolve;
            document.body.appendChild(s);
          });
        };

        const loadAll = async () => {
          await loadScript(scripts[0]); // Load jQuery first
          for(let i=1; i<scripts.length; i++) await loadScript(scripts[i]);
        };
        
        loadAll();
      };

      window.addEventListener('scroll', loadScripts, { passive: true, once: true });
      window.addEventListener('mousemove', loadScripts, { passive: true, once: true });
      window.addEventListener('touchstart', loadScripts, { passive: true, once: true });
      setTimeout(loadScripts, 3500); // Failsafe loader
    })();
  </script>
</body>
</html>
