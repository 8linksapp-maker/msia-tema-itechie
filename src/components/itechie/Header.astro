---
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';
import { slugify } from '../../lib/slugify';

const siteConfig = readData('siteConfig.json');
const menuItems = readData('menu.json', { items: [] }).items || [];

const categoriesData = readData('categories.json', []);
const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
const allCategories = finalCategoriesData;

const servicosData = readData('servicos.json', { serviceArea: { items: [] } });
const allServices = servicosData?.serviceArea?.items || [];

// menuHoverEnabled controla se o submenu abre passando o mouse (true) ou só ao clicar (false)
const menuHoverEnabled = siteConfig?.menuHoverEnabled !== false;
---

<header data-menu-hover={menuHoverEnabled ? 'on' : 'off'}>
  <div class="navbar-top style-2">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-3 d-lg-inline-block d-none ps-0">
          <div class="logo">
            <a href="/">
              {siteConfig.logo ? (
                <img src={siteConfig.logo} alt={siteConfig.name} style={`max-height: ${siteConfig.logoHeight || 50}px; height: auto; width: auto;`} />
              ) : (
                <span class="text-logo">{siteConfig.name}</span>
              )}
            </a>
          </div>
        </div>
        <div class="col-lg-9 d-lg-flex d-none justify-content-end align-items-center pe-0">
          <div class="media d-flex align-items-center me-4">
            <div class="media-left me-3">
              <i class="far fa-clock"></i>
            </div>
            <div class="media-body">
              <h6 class="mb-0">Horário de Atendimento</h6>
              <p class="mb-0">{siteConfig.header?.businessHours || 'Seg - Sex || 08:00 - 18:00'}</p>
            </div>
          </div>
          <div class="media d-flex align-items-center me-4">
            <div class="media-left me-3">
              <i class="far fa-envelope"></i>
            </div>
            <div class="media-body">
              <h6 class="mb-0">E-mail de Contato</h6>
              <p class="mb-0">{siteConfig.contact?.email || 'info@itechie.com'}</p>
            </div>
          </div>
          <div class="social-media-light ms-2">
            {siteConfig.social?.facebook && <a href={siteConfig.social.facebook}><i class="fab fa-facebook-f"></i></a>}
            {siteConfig.social?.twitter && <a href={siteConfig.social.twitter}><i class="fab fa-twitter"></i></a>}
            {siteConfig.social?.instagram && <a href={siteConfig.social.instagram}><i class="fab fa-instagram"></i></a>}
            {siteConfig.social?.linkedin && <a href={siteConfig.social.linkedin}><i class="fab fa-linkedin-in"></i></a>}
            {siteConfig.social?.youtube && <a href={siteConfig.social.youtube}><i class="fab fa-youtube"></i></a>}
          </div>
        </div>
      </div>
    </div>
  </div>

  <nav class="navbar navbar-area navbar-area-2 navbar-expand-lg bg-main-base" id="itechie-navbar">
    <div class="container nav-container">
<!-- Mobile menu removed to fix stray T -->
      <!-- Modern Mobile Menu Toggle -->
      <div class="mobile-toggle-wrapper d-lg-none">
        <button class="hamburger-menu" id="mobile-menu-btn" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="logo text-center flex-grow-1 d-lg-none">
        <a href="/">
          {siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} style={`max-height: ${siteConfig.logoHeight || 40}px;`} />
          ) : (
            <span class="text-logo" style="font-size: 20px;">{siteConfig.name}</span>
          )}
        </a>
      </div>

      <!-- Mobile Menu Overlay -->
      <div class="mobile-menu-overlay" id="mobile-menu-overlay">
        <div class="mobile-menu-content">
          <ul class="mobile-nav-list">
            {menuItems && menuItems.map((item: any) => {
              const hasSubmenu = (item.items && item.items.length > 0) || (item.showCategories && allCategories.length > 0) || (item.showServices && allServices.length > 0);
              return (
                <li class={hasSubmenu ? "has-dropdown" : ""}>
                  <div class="menu-item-row">
                    <a href={item.href}>{item.label}</a>
                    {hasSubmenu && <i class="fas fa-chevron-down toggle-dropdown"></i>}
                  </div>
                  {hasSubmenu && (
                    <ul class="mobile-dropdown">
                      {item.items?.map((subItem: any) => (
                        <li><a href={subItem.href}>{subItem.label}</a></li>
                      ))}
                      {item.showCategories && allCategories.map((cat: any) => (
                          <li><a href={`/categoria/${slugify(cat)}`}>{cat}</a></li>
                      ))}
                      {item.showServices && allServices.map((service: any) => (
                        <li><a href={`/servico/${service.slug}`}>{service.title}</a></li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
          <div class="mobile-menu-footer mt-5 text-center">
            <a class="it-btn btn-base w-100" href={siteConfig.header?.ctaLink || "/contato"}>{siteConfig.header?.ctaText || "Começar Agora"}</a>
          </div>
        </div>
      </div>

      <div class="collapse navbar-collapse" id="itechie_main_menu">
        <ul class="navbar-nav">
          {menuItems && menuItems.map((item: any) => {
            const hasSubmenu = (item.items && item.items.length > 0) || (item.showCategories && allCategories.length > 0) || (item.showServices && allServices.length > 0);
            return (
              <li class={hasSubmenu ? "menu-item-has-children" : ""}>
                <a href={item.href}>{item.label}</a>
                {hasSubmenu && (
                  <ul class="sub-menu">
                    {item.items?.map((subItem: any) => (
                      <li><a href={subItem.href}>{subItem.label}</a></li>
                    ))}
                    {item.showCategories && allCategories.map((cat: any) => (
                        <li><a href={`/categoria/${slugify(cat)}`}>{cat}</a></li>
                    ))}
                    {item.showServices && allServices.map((service: any) => (
                      <li><a href={`/servico/${service.slug}`}>{service.title}</a></li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })}
        </ul>
      </div>
      <div class="nav-right-part nav-right-part-desktop">
        <a class="it-btn btn-black btn-block-height" href={siteConfig.header?.ctaLink || "/contato"}>{siteConfig.header?.ctaText || "Começar Agora"}</a>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  const navbar = document.getElementById('itechie-navbar');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-menu-overlay');
  const dropdownToggles = document.querySelectorAll('.toggle-dropdown');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 100) {
      navbar.classList.add('sticky-active');
    } else {
      navbar.classList.remove('sticky-active');
    }
  });

  if (menuBtn && overlay) {
    menuBtn.addEventListener('click', () => {
      menuBtn.classList.toggle('active');
      overlay.classList.toggle('active');
      document.body.classList.toggle('no-scroll');
    });
  }

  // Accordion Logic for Mobile
  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      const parent = toggle.closest('li');
      const dropdown = parent.querySelector('.mobile-dropdown');
      dropdown.classList.toggle('active');
      toggle.classList.toggle('active');
    });
  });

  // Desktop dropdown — click toggle (acessibilidade + modo click-only)
  document.querySelectorAll('.menu-item-has-children > a').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      const li = trigger.closest('.menu-item-has-children');
      if (!li) return;
      e.preventDefault();
      const wasOpen = li.classList.contains('is-open');
      document.querySelectorAll('.menu-item-has-children.is-open').forEach(d => d.classList.remove('is-open'));
      if (!wasOpen) li.classList.add('is-open');
    });
  });
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.menu-item-has-children')) {
      document.querySelectorAll('.menu-item-has-children.is-open').forEach(d => d.classList.remove('is-open'));
    }
  });
</script>

<style>
  .navbar-top.style-2 {
    padding: 15px 0 !important;
    background: #fff !important;
  }
  .navbar-top.style-2 .logo img {
    max-height: 55px;
  }
  .navbar-top .media .media-left i {
    font-size: 24px;
    color: var(--main-color);
    margin-right: 15px;
  }
  .navbar-top .media .media-body h6 {
    margin-bottom: 0px;
    font-weight: 700;
    font-size: 15px;
  }
  .navbar-top .media .media-body p {
    margin-bottom: 0;
    font-size: 13px;
    color: #666;
  }
  .navbar-top .social-media-light a {
    background: #111;
    color: #fff;
    width: 32px;
    height: 32px;
    line-height: 32px;
    display: inline-block;
    border-radius: 50%;
    text-align: center;
    margin-left: 5px;
    font-size: 14px;
    transition: all 0.3s;
  }
  .navbar-top .social-media-light a:hover {
    background: var(--main-color);
  }

  /* BARRA DE NAVEGAÇÃO AZUL */
  .navbar-area-2 {
    background: var(--main-color) !important;
    padding: 0 !important;
  }
  .mobile-toggle-wrapper,
  .mobile-menu-overlay {
    display: none !important;
  }
  .nav-container {
    height: 80px; 
    display: flex;
    align-items: center;
    justify-content: space-between !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }
  .navbar-collapse {
    height: 100%;
  }
  @media (min-width: 992px) {
    .navbar-collapse {
      display: flex !important;
    }
  }
  .navbar-nav {
    display: flex !important;
    visibility: visible !important;
    opacity: 1 !important;
    align-items: center;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    flex-direction: row !important;
    justify-content: flex-start !important;
  }
  .navbar-nav li {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .navbar-nav li a {
    color: #fff !important;
    font-size: 18px !important;
    font-weight: 700 !important;
    text-transform: capitalize;
    padding: 0 20px !important;
    height: 100%;
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: 0.3s;
  }
  .navbar-nav > li:first-child > a {
    padding-left: 0 !important;
  }
  .navbar-nav li:hover > a {
    background: rgba(0,0,0,0.1);
  }

  /* DROPDOWN */
  .sub-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 250px;
    background: #fff;
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    padding: 15px 0;
    margin: 0;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    border-radius: 0 0 10px 10px;
    z-index: 999;
    transform: translateY(10px);
  }
  .navbar-nav li:hover .sub-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  /* Modo click-only: neutraliza hover, abre só via .is-open */
  header[data-menu-hover="off"] .navbar-nav li:hover .sub-menu {
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
  }
  /* Estado aberto via click sempre visível (em qualquer modo) */
  .navbar-nav li.menu-item-has-children.is-open > .sub-menu {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
  .navbar-nav li.menu-item-has-children.is-open > a:after {
    transform: rotate(180deg);
  }
  .sub-menu li {
    height: auto !important;
    display: block !important;
    width: 100%;
  }
  .sub-menu li a {
    color: #333 !important;
    padding: 12px 25px !important;
    font-size: 16px !important;
    font-weight: 600 !important;
    display: block !important;
    height: auto !important;
    background: transparent !important;
  }
  .sub-menu li a:hover {
    color: var(--main-color) !important;
    background: #f4f4ff !important;
  }

  /* ARROW */
  .menu-item-has-children > a:after {
    content: "\f107";
    font-family: "Font Awesome 5 Free";
    font-weight: 900;
    margin-left: 8px;
    font-size: 14px;
    transition: 0.3s;
  }
  .menu-item-has-children:hover > a:after {
    transform: rotate(180deg);
  }

  /* BOTÃO CTA */
  .btn-block-height {
    height: 80px !important;
    line-height: 25px !important; /* Ajuste para centralizar texto */
    padding: 0 35px !important;
    border-radius: 0 !important;
    background: #111111 !important;
    color: #fff !important;
    display: flex !important;
    align-items: center;
    border: none !important;
    font-weight: 700;
    font-size: 18px;
  }
  .btn-block-height:hover {
    background: #000 !important;
  }

  .nav-right-part-desktop {
    margin-right: 0px;
    height: 80px;
    display: flex !important;
    align-items: center;
  }

  @media (max-width: 991px) {
    .nav-right-part-desktop {
      display: none !important;
    }
  }

  /* MODERN MOBILE MENU REDESIGN */
  @media (max-width: 991px) {
    .nav-container { padding: 0 15px !important; }
    .navbar-collapse { display: none !important; }
    .mobile-toggle-wrapper { display: block !important; }
    
    .hamburger-menu {
      background: transparent;
      border: none;
      width: 40px;
      height: 40px;
      position: relative;
      z-index: 1001;
      cursor: pointer;
      padding: 0;
    }
    .hamburger-menu span {
      display: block;
      width: 25px;
      height: 2px;
      background: #fff;
      margin: 6px auto;
      transition: 0.3s;
    }
    .hamburger-menu.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .hamburger-menu.active span:nth-child(2) { opacity: 0; }
    .hamburger-menu.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

    .mobile-menu-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background: rgba(11, 13, 38, 0.95);
      backdrop-filter: blur(10px);
      z-index: 1000;
      opacity: 0;
      visibility: hidden;
      transition: all 0.4s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .mobile-menu-overlay.active {
      display: flex !important;
      opacity: 1;
      visibility: visible;
    }
    .mobile-menu-content {
      width: 90%;
      max-height: 80vh;
      overflow-y: auto;
    }
    .mobile-nav-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .mobile-nav-list li {
      margin-bottom: 20px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding-bottom: 15px;
    }
    .menu-item-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .mobile-nav-list li a {
      color: #fff;
      font-size: 24px;
      font-weight: 700;
      text-decoration: none;
    }
    .toggle-dropdown {
      color: #fff;
      font-size: 18px;
      transition: 0.3s;
    }
    .toggle-dropdown.active { transform: rotate(180deg); }
    
    .mobile-dropdown {
      list-style: none;
      padding-left: 20px;
      margin-top: 15px;
      display: none;
    }
    .mobile-dropdown.active { display: block; }
    .mobile-dropdown li {
      margin-bottom: 10px;
      border: none;
      padding: 0;
    }
    .mobile-dropdown li a {
      font-size: 18px;
      font-weight: 500;
      opacity: 0.8;
    }
    
    .no-scroll { overflow: hidden; }
  }

  .sticky-active {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 999;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
  }

  .text-logo {
    font-size: 28px;
    font-weight: 900;
    color: var(--main-color);
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 1;
    display: inline-block;
  }
  .navbar-area-2 .text-logo {
      color: #fff;
      font-size: 24px;
  }
</style>
