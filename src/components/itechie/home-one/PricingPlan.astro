---
import { readData } from '../../../lib/readData';
const servicosData = readData('servicos.json');
const { data = servicosData.pricing } = Astro.props;
const pricing = data || { title: "", subtitle: "", description: "", btnText: "", btnLink: "", plans: [] };
---

<div class="pricing-area pd-top-120 pd-bottom-90">
   <div class="container">
      <div class="section-title">
         <div class="row align-items-center">
            <div class="col-xl-6">
               <h5 class="sub-title right-line">{pricing.subtitle}</h5>
               <h2 class="title">{pricing.title}</h2>
               <p class="content mt-2">{pricing.description}</p>
            </div>
            {pricing.btnText && (
               <div class="col-xl-6 text-xl-end mt-4 mt-xl-0">
                  <a class="it-btn btn-border-base" href={pricing.btnLink || "/servicos"}>{pricing.btnText}</a>
               </div>
            )}
         </div>
      </div>

      <div class="row justify-content-center">
         {pricing.plans?.map((item: any) => (
            <div class="col-lg-4 col-md-6">
               <div class={`single-pricing-inner style-1 ${item.active ? 'active' : ''}`}>
                  <div class="header text-center">
                     <h3>{item.plan}</h3>
                     <div class="price-container">
                        <div class="price-wrapper">
                           <span class="currency">R$</span>
                           <h2 class="price-val">{item.price}</h2>
                        </div>
                        <sub class="billing">{item.billingPeriod || "por mês cobrança anual"}</sub>
                     </div>
                  </div>
                  <div class="details">
                     <ul class="single-list-inner list-unstyled">
                        {item.features?.map((list: any) => (
                           <li class={list.class_name}><i class="fas fa-check-circle me-2"></i>{list.list}</li>
                        ))}
                     </ul>
                     <a class="it-btn btn-black w-100" href="#">Começar Agora</a>
                  </div>
               </div>
            </div>
         ))}
      </div>
   </div>
</div>

<style>
  .single-pricing-inner {
    background: #fff;
    padding: 50px 40px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    border-radius: 10px;
    margin-bottom: 30px;
    transition: 0.3s;
    border: 1px solid transparent;
  }
  .single-pricing-inner.active {
    border-color: var(--main-color);
  }
  .single-pricing-inner:hover {
    transform: translateY(-10px);
    background: var(--main-color);
  }
  .single-pricing-inner:hover h3,
  .single-pricing-inner:hover .price-val,
  .single-pricing-inner:hover .currency,
  .single-pricing-inner:hover .billing,
  .single-pricing-inner:hover .single-list-inner li,
  .single-pricing-inner:hover .single-list-inner li i {
    color: #fff !important;
  }
  .currency {
    font-size: 24px;
    font-weight: 700;
    color: var(--main-color);
    margin-right: 5px;
  }
  .price-val {
    font-size: 50px;
    font-weight: 800;
    color: var(--main-color);
    margin: 0;
    line-height: 1;
  }
  .billing {
    font-size: 14px;
    color: #666;
    margin-top: 5px;
    display: block;
    position: relative;
    top: 0;
  }
  .single-pricing-inner .header h3 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 25px;
    text-transform: uppercase;
  }
  .price h2 {
    font-size: 50px;
    font-weight: 800;
    color: var(--main-color);
  }
  .price sup {
    font-size: 24px;
    top: -15px;
    color: var(--main-color);
  }
  .price sub {
    font-size: 14px;
    color: #666;
  }
  .single-list-inner {
    margin: 30px 0;
  }
  .single-list-inner li {
    margin-bottom: 12px;
    font-weight: 500;
  }
  .single-list-inner li i {
    color: var(--main-color);
  }
  .single-list-inner li.disable {
    opacity: 0.5;
    text-decoration: line-through;
  }
</style>
