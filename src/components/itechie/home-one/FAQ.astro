---
import { readData } from '../../../lib/readData';
const sobreData = readData('sobre.json');
const faq = sobreData?.faq || { title: "", subtitle: "", items: [] };
---

<div class="faq-area pd-top-120 pd-bottom-120">
   <div class="container">
      <div class="row">
         <div class="col-lg-6 col-md-8 order-lg-last mb-4 mb-lg-0">
            <div class="faq-image-wrap">
               <div class="thumb">
                  <img src={faq.image || "/itechie-assets/img/about/f1.webp"} alt="img" style="border-radius: 10px;" />
               </div>
            </div>
         </div>
         <div class="col-lg-6 pe-xl-5 order-lg-first align-self-center">
            <div class="section-title mb-0">
               <h5 class="sub-title right-line">{faq.subtitle}</h5>
               <h2 class="title">{faq.title}</h2>
               <p class="content">{faq.description || "Tiramos suas dúvidas para que você possa focar no que realmente importa: o seu negócio."}</p>
            </div>
            <div class="accordion mt-4" id="accordionFAQ">
               {faq.items?.map((item: any, index: number) => (
                  <div class="accordion-item single-accordion-inner">
                     <h2 class="accordion-header" id={`fqheading${index}`}>
                        <button
                           class={`accordion-button ${index === 0 ? "" : "collapsed"}`}
                           type="button"
                           data-bs-toggle="collapse"
                           data-bs-target={`#fqcollapse${index}`}
                           aria-expanded={index === 0 ? "true" : "false"}
                           aria-controls={`fqcollapse${index}`}
                        >
                           {item.q}
                        </button>
                     </h2>
                     <div
                        id={`fqcollapse${index}`}
                        class={`accordion-collapse collapse ${index === 0 ? "show" : ""}`}
                        aria-labelledby={`fqheading${index}`}
                        data-bs-parent="#accordionFAQ"
                     >
                        <div class="accordion-body">{item.a}</div>
                     </div>
                  </div>
               ))}
            </div>
         </div>
      </div>
   </div>
</div>

<style>
  .faq-image-wrap {
    position: relative;
    padding-left: 30px;
    padding-bottom: 30px;
  }
  .faq-image-wrap .thumb {
    position: relative;
  }
  .img-position-1 {
    position: absolute;
    right: -20px;
    bottom: -20px;
    z-index: 2;
    max-width: 50%;
  }
  .img-position-2 {
    position: absolute;
    left: -30px;
    top: -30px;
    z-index: -1;
  }
  .accordion-item {
    border: 1px solid #e9eaff;
    margin-bottom: 15px;
    border-radius: 5px !important;
    overflow: hidden;
  }
  .accordion-button {
    font-weight: 700;
    font-size: 18px;
    color: #111;
    background: #fff;
    padding: 20px;
  }
  .accordion-button:not(.collapsed) {
    background: var(--main-color) !important;
    color: #fff;
  }
  .accordion-button::after {
    filter: brightness(0);
  }
  .accordion-button:not(.collapsed)::after {
    filter: brightness(1);
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23fff'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e");
  }
  .accordion-body {
    padding: 20px;
    color: #666;
    line-height: 1.6;
  }
</style>
