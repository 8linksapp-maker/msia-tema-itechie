---
import { readData } from '../../../lib/readData';
const sobreData = readData('sobre.json');
const skillArea = sobreData?.skillArea2 || { title: "", subtitle: "", description: "", image: "", skills: [] };
---

<div class="skill-area bg-relative pd-top-120 pd-bottom-120 bg-light-base">
   <div class="container">
      <div class="row">
         <div class="col-lg-6 pe-5 mb-5 mb-lg-0">
            <div class="section-title mb-0">
               <h5 class="sub-title left-border">{skillArea.subtitle}</h5>
               <h2 class="title">{skillArea.title}</h2>
               <p class="content">{skillArea.description}</p>
            </div>
            <div class="skill-progress-area mt-4">
               {skillArea.skills?.map((item: any) => (
                  <div class="single-progressbar">
                     <h6>{item.name}</h6>
                     <div class="progress-bg">
                        <div class="progress-rate bg-main-base" style={`width: ${item.percentage}%`}></div>
                        <div class="progress-count-wrap">
                           <span class="progress-count" style="color: var(--main-color);">{item.percentage}</span>
                           <span class="counting-icons" style="color: var(--main-color);">%</span>
                        </div>
                     </div>
                  </div>
               ))}
            </div>
         </div>

         <div class="col-lg-6 px-lg-5">
            <div class="about-mask-bg-wrap about-mask-bg-wrap-1 mb-4 mb-lg-0">
               <div class="shape-image-sm top_image_bounce mask-primary" style="mask-image: url(/itechie-assets/img/about/1sm.webp);"></div>
               <div class="shape-image mask-primary" style="mask-image: url(/itechie-assets/img/about/1s.webp); opacity: 0.3;"></div>
               <div class="thumb">
                  <img src={skillArea.image || "/itechie-assets/img/about/6.webp"} alt="img" style="border-radius: 10px;" />
               </div>
            </div>
         </div>
      </div>
   </div>
</div>

<style>
  .skill-progress-area .single-progressbar {
    margin-bottom: 25px;
  }
  .skill-progress-area .single-progressbar h6 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .progress-bg {
    height: 10px;
    width: 100%;
    background: #fff;
    border-radius: 5px;
    position: relative;
    border: 1px solid rgba(0,0,0,0.05);
  }
  .progress-rate {
    height: 100%;
    border-radius: 5px;
    position: relative;
    transition: 2s ease-in-out;
  }
  .progress-count-wrap {
    position: absolute;
    right: 0;
    top: -30px;
    font-weight: 700;
  }
  .about-mask-bg-wrap-1 {
    position: relative;
    padding-left: 50px;
    padding-top: 50px;
  }
  .about-mask-bg-wrap-1 .thumb img {
    mask-image: url(/itechie-assets/img/about/1m.webp);
    -webkit-mask-image: url(/itechie-assets/img/about/1m.webp);
    mask-repeat: no-repeat;
    mask-size: contain;
    width: 100%;
  }
  .shape-image-sm {
    position: absolute;
    left: 0;
    top: 0;
    width: 120px;
    height: 120px;
    z-index: 2;
  }
  .shape-image {
    position: absolute;
    left: 20px;
    top: 20px;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
</style>
