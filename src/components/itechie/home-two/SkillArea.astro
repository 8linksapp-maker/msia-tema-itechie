---
import { readData } from '../../../lib/readData';
const homeData = readData('home.json');
const skillArea = homeData?.skillArea || { title: "Bringing new it business solutions and ideas", subtitle: "Professional Skill", description: "Maecenas tempus, tellus eget condime...", skills: [] };
const skills = skillArea.skills;
---

<div class="skill-area bg-relative pd-top-120 pd-bottom-120">
  <div class="container">
    <div class="row">
      <div class="col-lg-6 pe-lg-5 mb-5 mb-lg-0">
        <div class="section-title mb-0">
          <h5 class="sub-title left-border">{skillArea.subtitle}</h5>
          <h2 class="title">{skillArea.title}</h2>
          <p class="content">{skillArea.description}</p>
        </div>
        <div class="skill-progress-area mt-4">
          {skills.map((skill) => (
            <div class="single-progressbar">
              <h6>{skill.title}</h6>
              <div class="progress-item">
                <div class="progress-rate" data-finish={skill.percentage} style="width: 0%;">
                  <div class="progress-count-wrap">
                    <span class="progress-count">{skill.percentage}</span>
                    <span class="counting-icons">%</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="col-lg-6 px-xl-5">
        <div class="row">
          <div class="col-lg-12">
            <div class="thumb border-radius-5 mb-4 image-hover-animate">
              <img src={skillArea.image1 || "/itechie-assets/img/other/4.webp"} alt="Skill Image 1" class="w-100" width="570" height="350" loading="lazy" decoding="async" style="border-radius: 5px; object-fit: cover;" />
            </div>
          </div>
          <div class="col-md-6">
            <div class="thumb border-radius-5 image-hover-animate mb-3 mb-md-0">
              <img src={skillArea.image2 || "/itechie-assets/img/other/5.webp"} alt="Skill Image 2" class="w-100" width="270" height="200" loading="lazy" decoding="async" style="border-radius: 5px; object-fit: cover;" />
            </div>
          </div>
          <div class="col-md-6">
            <div class="thumb border-radius-5 image-hover-animate">
              <img src={skillArea.image3 || "/itechie-assets/img/other/6.webp"} alt="Skill Image 3" class="w-100" width="270" height="200" loading="lazy" decoding="async" style="border-radius: 5px; object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // Simple Animation for Progress Bars
  const observerOptions = {
    threshold: 0.5
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const progressBar = entry.target.querySelector('.progress-rate');
        if (progressBar) {
          const finish = progressBar.getAttribute('data-finish');
          progressBar.style.width = finish + '%';
        }
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.single-progressbar').forEach(item => {
    observer.observe(item);
  });
</script>
