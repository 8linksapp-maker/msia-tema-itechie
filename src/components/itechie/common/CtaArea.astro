---
import { readData } from '../../../lib/readData';
const sobreData = readData('sobre.json');
const { data = sobreData?.cta } = Astro.props;
const cta = data || { title: "", subtitle: "Estamos aqui para responder suas perguntas 24/7", bgImage: "", btnText: "", btnLink: "" };
---

<div class="call-to-action-area pd-top-120 pd-bottom-120 text-center"
   style={`background-color: var(--main-color); position: relative;`}>
   <div class="cms-overlay-base" style="background-color: var(--main-color); opacity: 1;"></div>
   <div class="container" style="position: relative; z-index: 2;">
      <div class="row justify-content-center">
         <div class="col-lg-6 col-md-8">
            <div class="single-call-to-action-inner style-white">
               <h5>{cta.subtitle || "Estamos aqui para responder suas perguntas 24/7"}</h5>
               <h2>{cta.title}</h2>
               <a class="it-btn btn-black mt-3" href={cta.btnLink || "/contato"}>{cta.btnText || "Fale Conosco"}</a>
            </div>
         </div>
      </div>
   </div>
</div>

<style>
  .call-to-action-area {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .cms-overlay-base {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    left: 0;
    top: 0;
    background-color: var(--main-color);
    opacity: 0.9;
    z-index: 1;
  }
  .single-call-to-action-inner.style-white h5 {
    color: #fff;
    font-size: 18px;
    margin-bottom: 10px;
    text-transform: uppercase;
  }
  .single-call-to-action-inner.style-white h2 {
    color: #fff;
    font-size: 45px;
    font-weight: 700;
    margin-bottom: 30px;
  }
</style>
