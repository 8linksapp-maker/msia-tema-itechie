---
import { BLOG_BASE } from '../../lib/postUrl';
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';
const siteConfig = readData('siteConfig.json');
const categoriesData = readData('categories.json', []);

const posts = await getCollection('blog');
const categoriesFromPosts = [...new Set(posts.map(post => post.data.category).filter(Boolean))];
const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
const allCategories = finalCategoriesData.length > 0 ? finalCategoriesData : categoriesFromPosts;
---

<footer class="bg-primary-600 text-white">
  <div class="max-w-7xl mx-auto px-4 pt-14 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-white/20">

      <!-- Coluna 1: Sobre -->
      <div>
        <a href="/" class="inline-block mb-4">
          {siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} class="h-10 w-auto object-contain filter brightness-0 invert" />
          ) : (
            <span class="text-2xl font-bold text-white">{siteConfig.name}</span>
          )}
        </a>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          {siteConfig.description}
        </p>
        <!-- Social icons -->
        <div class="flex items-center gap-3">
          {siteConfig.social?.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer"
               class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer"
               class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.facebook && (
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer"
               class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          )}
          {siteConfig.social?.linkedin && (
const latestPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 2);

function formatDate(date: Date) {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long' });
}
---

<footer class="footer-area bg-cover bg-base footer-area-3" style={`background-image: url('${siteConfig.footer?.backgroundImage || "/itechie-assets/img/bg/2.webp"}')`}>
  <div class="container">
    <div class="row">
      <div class="col-lg-4 col-md-6">
        <div class="widget widget_about">
          <h4 class="widget-title">
            <a href="/"><img src="/itechie-assets/img/logo.webp" alt="Logo" style="max-height: 50px;" /></a>
          </h4>
          <div class="details">
            <p>{siteConfig.description || "Transformamos marcas através de estratégias digitais de alta performance, SEO e Design focado em conversão."}</p>
            <ul class="social-media mt-4">
              {siteConfig.social?.facebook && <li><a href={siteConfig.social.facebook}><i class="fab fa-facebook-f"></i></a></li>}
              {siteConfig.social?.twitter && <li><a href={siteConfig.social.twitter}><i class="fab fa-twitter"></i></a></li>}
              {siteConfig.social?.instagram && <li><a href={siteConfig.social.instagram}><i class="fab fa-instagram"></i></a></li>}
              {siteConfig.social?.linkedin && <li><a href={siteConfig.social.linkedin}><i class="fab fa-linkedin-in"></i></a></li>}
            </ul>
          </div>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="widget widget_nav_menu">
          <h4 class="widget-title">Links Rápidos</h4>
          <ul>
            <li><a href="/">Página Inicial</a></li>
            <li><a href="/sobre">Sobre Nós</a></li>
            <li><a href="/servicos">Nossos Serviços</a></li>
            <li><a href="/blog">Blog & Notícias</a></li>
            <li><a href="/contato">Fale Conosco</a></li>
            <li><a href="/privacidade">Política de Privacidade</a></li>
            <li><a href="/termos">Termos de Uso</a></li>
          </ul>
        </div>
      </div>

      <div class="col-lg-4 col-md-12">
        <div class="widget widget-recent-post">
          <h4 class="widget-title">Notícias Recentes</h4>
          <ul>
            {latestPosts.map((post, index) => (
              <li class={index > 0 ? "mt-3" : ""}>
                <div class="media">
                  <div class="media-left">
                    <img src={post.data.heroImage || "/itechie-assets/img/blog/1.webp"} alt={post.data.title} style="width: 60px; height: 60px; object-fit: cover; border-radius: 5px;" />
                  </div>
                  <div class="media-body align-self-center">
                    <h6 class="title"><a href={`${BLOG_BASE}/${post.slug}`}>{post.data.title}</a></h6>
                    <div class="post-info"><i class="far fa-calendar-alt"></i> <span>{formatDate(post.data.pubDate)}</span></div>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
    <!-- Barra copyright -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/50 text-xs">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Todos os direitos reservados.
      </p>
      <div class="flex items-center gap-4">
        <a href="/privacidade" class="text-white/50 hover:text-white/80 text-xs transition-colors">Privacidade</a>
        <a href="/termos" class="text-white/50 hover:text-white/80 text-xs transition-colors">Termos</a>
      </div>
    </div>
  </div>
</footer>
