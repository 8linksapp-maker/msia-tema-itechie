---
import ItechieLayout from '../layouts/ItechieLayout.astro';
import Breadcrumb from '../components/itechie/Breadcrumb.astro';
import ContactForm from '../components/itechie/contact-page/ContactForm.astro';

import { readData } from '../lib/readData';
const contatoData = readData('contato.json');
const intro = contatoData?.intro || { title: "", subtitle: "", description: "" };
const contactBlocks = contatoData?.contactBlocks || { items: [] };
---

<ItechieLayout title={contatoData.breadcrumb?.title || "Contato"}>
  <Breadcrumb title={contatoData.breadcrumb?.title || "Fale Conosco"} subTitle={contatoData.breadcrumb?.subtitle || "Contato"} />
  
  <div class="info-box-area pd-top-115 pd-bottom-90">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-6 col-md-9">
          <div class="section-title text-center">
            <h5 class="sub-title double-line">{intro.subtitle}</h5>
            <h2 class="title">{intro.title}</h2>
            <p class="content">{intro.description}</p>
          </div>
        </div>
      </div>
      <div class="row flex-nowrap overflow-auto pb-4 contact-scroll" style="margin-right: -15px; margin-left: -15px;">
         {contactBlocks.items?.map((item: any) => (
            <div class="col-lg-4 col-md-6 flex-shrink-0" style="min-width: 350px;">
               <div class="single-contact-inner text-center h-100">
                  <div class="icon-box">
                     <i class={item.icon}></i>
                  </div>
                  <div class="details-wrap">
                     <div class="details-inner">
                        <h3>{item.title}</h3>
                        <p set:html={item.text}></p>
                     </div>
                  </div>
               </div>
            </div>
         ))}
      </div>
    </div>
  </div>

  <ContactForm />

</ItechieLayout>

<style is:global>
  .contact-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--main-color) rgba(0,0,0,0.05);
  }
  .contact-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .contact-scroll::-webkit-scrollbar-thumb {
    background: var(--main-color);
    border-radius: 10px;
  }
  .single-contact-inner {
    padding: 50px 30px;
    background: #f9f9ff;
    border-radius: 10px;
    transition: 0.3s;
    border: 1px solid transparent;
  }
  .single-contact-inner:hover {
    background: #fff;
    border-color: var(--main-color);
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
  }
  .icon-box {
    font-size: 50px;
    color: var(--main-color);
    margin-bottom: 25px;
  }
</style>
